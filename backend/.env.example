# =============================================================================
# University ERP - Backend Environment Variables
# =============================================================================
#
# OPTION B ARCHITECTURE (Zero Credit Card):
#   Backend:  Render free tier
#   Database: Supabase free tier
#   Frontend: Vercel free tier
#
# =============================================================================

# --- DATABASE (Supabase) ---
# 1. Go to https://supabase.com and create a free account (no credit card)
# 2. Create a new project (pick a region close to you, e.g., Mumbai for India)
# 3. Set a database password (save it!)
# 4. After project is created, click "Connect" button at top
# 5. Select "Session pooler" tab (port 5432)
# 6. Copy the URI and paste below, replacing [YOUR-PASSWORD] with your DB password
#
# Format: postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

DATABASE_URL=postgresql://postgres.abcdefghijkl:YOUR_PASSWORD_HERE@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# --- JWT SECRET ---
# Generate a random string. On Linux/Mac: openssl rand -hex 32
SECRET_KEY=change-me-generate-a-random-secret

# --- FRONTEND URL (for CORS) ---
# Set this to your Vercel deployment URL after deploying the frontend
FRONTEND_URL=http://localhost:3000
